  "attributes": {
    "fightingStrength": {
      "id": "fightingStrength",
      "name": {
        "en": "Fighting Strength"
      },
      "description": {
        "en": "Adds to hero personal attack and defense in combat."
      },
      "effect": {
        "type": "heroCombat",
        "perPoint": {
          "attack": 1,
          "defenseInfantry": 1,
          "defenseCavalry": 1
        }
      },
      "tribeScaling": true
    },
    "offBonus": {
      "id": "offBonus",
      "name": {
        "en": "Off Bonus"
      },
      "description": {
        "en": "Increases attack of all troops in armies led by the hero."
      },
      "effect": {
        "type": "armyAttackPercent",
        "perPoint": 0.2,
        "maxPercent": 20
      }
    },
    "defBonus": {
      "id": "defBonus",
      "name": {
        "en": "Def Bonus"
      },
      "description": {
        "en": "Increases defense of all own troops in armies with the hero."
      },
      "effect": {
        "type": "armyDefensePercent",
        "perPoint": 0.2,
        "maxPercent": 20
      }
    },
    "resources": {
      "id": "resources",
      "name": {
        "en": "Resources"
      },
      "description": {
        "en": "Boosts resource production in the hero home village."
      },
      "effect": {
        "type": "homeVillageProductionPercent",
        "perPoint": 0.5,
        "maxPercent": 25
      }
    }
  },
